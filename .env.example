# Outpost Vostok — Supabase backend (Gogi shared project; per-app table namespace)
# Frontend (the Godot web bridge) uses the anon key + this prefix.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Per-app table prefix. The leaderboard table is "<VITE_TABLE_PREFIX>_scores".
VITE_TABLE_PREFIX=usr_nmexs7bytxq2_last_light
